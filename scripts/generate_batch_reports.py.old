#!/usr/bin/env python3
"""
generate_batch_reports.py - 批量生成竞品价格分析报告
支持导出：Markdown / HTML / PDF（需要wkhtmltopdf）

用法:
python scripts/generate_batch_reports.py --input examples/three_hotels.json --output reports/ --api-key YOUR_AMAP_KEY
"""

import os
import json
import argparse
from datetime import datetime
from typing import List, Dict

import sys
sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

from core.amap_client import AmapClientWrapper as AmapClient
from core.competitor_filter_v2 import HotelPOI, filter_competitors_v2, FilterConfig, get_config_for_scenario, filter_competitors_grouped, GroupedCompetitors
from algorithm.pricing_advisor import PricingAdvisor, CompetitorData, DemandLevel, PricingRecommendation

# ── 报告模板 ─────────────────────────────────────────────────

MARKDOWN_TEMPLATE = """# {hotel_name} 竞品价格分析报告
**生成时间**: {generated_at}  
**目标日期**: {target_date}  
**酒店位置**: {district} {lat}, {lon}  

## 酒店基础信息

| 项目 | 值 |
|------|-----|
| 品牌 | {brand} |
| 星级 | {star} |
| 平日基准价 | ¥{weekday_price} |
| 搜索范围 | {max_distance_km}km |
| 场景配置 | {scenario} |

## 竞品筛选结果

### 强相关竞品（AI调价分析使用）

{competitor_table}

### 分组市场全景展示

#### 按品牌分组

| 分组 | 数量 |
|------|------|
| 外资品牌竞品 | {count_foreign} |
| 内资品牌竞品 | {count_domestic} |

#### 按价格区间分组（每组最多10家）

| 价格区间 | 数量 |
|----------|------|
| 低于目标 × 0.7（低价位） | {count_price_low} |
| 目标 × 0.7 ~ 1.3（中价位） | {count_price_mid} |
| 高于目标 × 1.3（高价位） | {count_price_high} |

{auto_expand_note}

## 调价建议

**分析基于 {competitor_count} 家强相关有效竞品**

| 策略 | 推荐价格 | 涨幅 |
|------|----------|------|
| 🛡️ 保守 | ¥{price_conservative} | +{rate_conservative:.1f}% |
| ⚖️ 标准 | ¥{price_standard} | +{rate_standard:.1f}% |
| 🚀 激进 | ¥{price_aggressive} | +{rate_aggressive:.1f}% |

**推荐策略**: {strategy_emoji} **{strategy_name}** ¥{price_recommended}  
**置信度**: {confidence}%  
**推荐涨幅**: +{rate_recommended:.1f}%

## 分析依据

{reasoning}

## 关键洞察

{key_insight}

---

*generated by hotel-compete-report v3.1*
"""

HTML_TEMPLATE = """<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{hotel_name} - 竞品价格分析报告</title>
<style>
body {{ font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif; max-width: 900px; margin: 0 auto; padding: 20px; line-height: 1.6; color: #333; }}
h1 {{ color: #2c3e50; border-bottom: 2px solid #eee; padding-bottom: 10px; }}
h2 {{ color: #34495e; margin-top: 30px; }}
table {{ width: 100%; border-collapse: collapse; margin: 20px 0; }}
th, td {{ border: 1px solid #ddd; padding: 12px; text-align: left; }}
th {{ background-color: #f8f9fa; font-weight: 600; }}
.insight {{ background-color: #f0f8ff; padding: 15px; border-radius: 5px; margin: 20px 0; }}
.footer {{ color: #7f8c8d; font-size: 0.9em; text-align: center; margin-top: 50px; padding-top: 20px; border-top: 1px solid #eee; }}
</style>
</head>
<body>
<h1>{hotel_name}</h1>
<p><strong>生成时间:</strong> {generated_at}<br>
<strong>目标日期:</strong> {target_date}<br>
<strong>酒店位置:</strong> {district} {lat}, {lon}</p>

<h2>酒店基础信息</h2>
<table>
<tr><td>品牌</td><td>{brand}</td></tr>
<tr><td>星级</td><td>{star}</td></tr>
<tr><td>平日基准价</td><td>¥{weekday_price}</td></tr>
<tr><td>搜索范围</td><td>{max_distance_km}km</td></tr>
<tr><td>场景配置</td><td>{scenario}</td></tr>
</table>

<h2>竞品筛选结果</h2>
{competitor_table_html}

<h2>调价建议</h2>
<p><strong>分析基于 {competitor_count} 家有效竞品</strong></p>
<table>
<tr><th>策略</th><th>推荐价格</th><th>涨幅</th></tr>
{pricing_rows_html}
</table>

<p><strong>推荐策略:</strong> {strategy_emoji} <strong>{strategy_name}</strong> ¥{price_recommended}<br>
<strong>置信度:</strong> {confidence}%<br>
<strong>推荐涨幅:</strong> +{rate_recommended:.1f}%</p>

<h2>分析依据</h2>
<ul>
{reasoning_html}
</ul>

<div class="insight">
<h3>关键洞察</h3>
<p>{key_insight}</p>
</div>

<div class="footer">
generated by hotel-compete-report v3.1
</div>
</body>
</html>
"""

# ── 报告生成器 ───────────────────────────────────────────────

class ReportGenerator:
    def __init__(self, amap_api_key: str):
        self.amap = AmapClient(amap_api_key)

    def generate_report(self, hotel_info: Dict, output_dir: str) -> Dict:
        """生成单家酒店报告"""
        # 1. 高德POI搜索周边酒店
        lat = hotel_info["lat"]
        lon = hotel_info["lon"]
        radius_km = hotel_info.get("max_distance_km", 5)
        scenario = hotel_info.get("scenario", "default")

        print(f"🔍 搜索 {hotel_info['name']} 周边 {radius_km}km...")
        # 周边搜索关键词"酒店"
        nearby_pois = self.amap.poi_around(
            keywords="酒店",
            location=(lon, lat),
            radius_km=radius_km,
            page_size=50
        )
        # 计算距离并整理
        nearby_hotels = []
        center_lon, center_lat = lon, lat
        for poi in nearby_pois:
            # 计算距离
            if poi.lon and poi.lat:
                from math import radians, sin, cos, sqrt, atan2
                R = 6371
                dlon = radians(poi.lon - center_lon)
                dlat = radians(poi.lat - center_lat)
                a = sin(dlat/2)**2 + cos(radians(center_lat)) * cos(radians(poi.lat)) * sin(dlon/2)**2
                c = 2 * atan2(sqrt(a), sqrt(1-a))
                distance_km = R * c
                poi.distance_km = distance_km
                nearby_hotels.append(poi)
        # 按距离排序
        nearby_hotels.sort(key=lambda x: x.distance_km if x.distance_km else 999)
        print(f"   找到 {len(nearby_hotels)} 家酒店")

        # 2. 转换为HotelPOI对象
        target = HotelPOI(
            name=hotel_info["name"],
            location=f"{lon},{lat}",
            star=hotel_info["star"],
            brand=hotel_info["brand"],
            price=hotel_info["weekday_price"]
        )

        candidates = []
        for h in nearby_hotels:
            # 排除自己（名称完全匹配排除，部分匹配保留）
            if h.name.strip() != hotel_info["name"].strip():
                poi = HotelPOI(
                    name=h.name,
                    location=f"{h.lon},{h.lat}",
                    star=h.type if h.type else "高档型",
                    brand=self._extract_brand(h.name),
                    distance_km=h.distance_km
                )
                candidates.append(poi)
        print(f"   排除自身后剩余 {len(candidates)} 家候选")

        # 3. v2.1分组筛选
        config = get_config_for_scenario(scenario) if scenario != "default" else FilterConfig()
        grouped = filter_competitors_grouped(candidates, target, hotel_info["weekday_price"], config=config)
        filtered_scores = grouped.strong_relevant

        print(f"   筛选出 {len(filtered_scores)} 家强相关有效竞品")

        # 4. 准备竞品数据给调价算法
        # 这里假设：竞品平日价 = 当前价格，假日价 = 平日价 * (1 + 平均涨幅估算)
        # 实际生产环境应该从飞猪API获取真实假日价
        competitor_data = []
        for s in filtered_scores[:8]:  # 取Top 8
            # 简化：假设假日平均涨幅50%（实际应从API获取）
            est_holiday = s.hotel.price * 1.5 if s.hotel.price else hotel_info["weekday_price"] * 1.5
            cd = CompetitorData(
                name=s.hotel.name,
                base_price=s.hotel.price if s.hotel.price else hotel_info["weekday_price"],
                holiday_price=est_holiday,
                star=s.hotel.star,
                brand=s.hotel.brand,
                distance_km=s.hotel.distance_km if s.hotel.distance_km else 0
            )
            competitor_data.append(cd)

        # 5. 调价分析
        # 五一假期，需求高
        advisor = PricingAdvisor(
            base_price=hotel_info["weekday_price"],
            competitors=competitor_data,
            demand_level=DemandLevel.HIGH,
            target_date=hotel_info["target_date"]
        )
        recommendation = advisor.analyze()

        # 6. 生成markdown
        markdown = self._render_markdown(hotel_info, recommendation, grouped)
        html = self._render_html(hotel_info, recommendation, grouped)

        # 7. 保存文件
        hotel_slug = self._slugify(hotel_info["name"])
        generated_at = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

        md_path = os.path.join(output_dir, f"{hotel_slug}.md")
        html_path = os.path.join(output_dir, f"{hotel_slug}.html")

        with open(md_path, "w", encoding="utf-8") as f:
            f.write(markdown)
        with open(html_path, "w", encoding="utf-8") as f:
            f.write(html)

        print(f"   报告已保存: {md_path}")

        return {
            "hotel": hotel_info["name"],
            "markdown": md_path,
            "html": html_path,
            "competitor_count": len(filtered_scores),
            "recommendation": recommendation
        }

    def _slugify(self, s: str) -> str:
        return s.replace(" ", "-").replace("酒店", "").replace("大酒店", "").lower()

    def _extract_brand(self, name: str) -> str:
        """从酒店名提取品牌"""
        brands = ["开元", "洲际", "万豪", "希尔顿", "皇冠假日", "万丽", "洲际", "香格里拉"]
        for b in brands:
            if b in name:
                return b
        return ""

    def _render_markdown(self, hotel_info: Dict, rec: PricingRecommendation, grouped: GroupedCompetitors) -> str:
        # 强相关竞品表格
        competitor_rows = []
        competitor_rows.append("| 竞品名称 | 距离 | 星级 | 总分 |")
        competitor_rows.append("|----------|------|------|------|")
        for s in grouped.strong_relevant:
            dist = f"{s.hotel.distance_km:.1f}km" if s.hotel.distance_km else "N/A"
            competitor_rows.append(f"| {s.hotel.name} | {dist} | {s.hotel.star} | {s.total_score:.1f} |")
        competitor_table = "\n".join(competitor_rows)

        # 分组统计
        count_foreign = len(grouped.foreign_brands)
        count_domestic = len(grouped.domestic_brands)
        count_price_low = len(grouped.by_price_tier.get("low", []))
        count_price_mid = len(grouped.by_price_tier.get("mid", []))
        count_price_high = len(grouped.by_price_tier.get("high", []))

        auto_expand_note = ""
        if grouped.auto_expanded:
            auto_expand_note = "\n> ℹ️ 初始半径竞品太少，已自动扩展搜索半径" 

        # 替代方案
        alt = {a["strategy"]: a for a in rec.alternatives}
        cons = alt.get("conservative", {})
        std = alt.get("standard", {})
        agg = alt.get("aggressive", {})

        #  reasoning
        reasoning_list = "\n".join([f"- {r}" for r in rec.reasoning])

        # 关键洞察
        if rec.cpi_score > 120:
            insight = f"目标酒店CPI={rec.cpi_score:.1f}，当前定位高于竞品平均，可以考虑{rec.strategy.value}策略追求更高收益。"
        elif rec.cpi_score > 90:
            insight = f"目标酒店CPI={rec.cpi_score:.1f}，定位与竞品平均相当，标准策略性价比最佳。"
        else:
            insight = f"目标酒店CPI={rec.cpi_score:.1f}，当前价格低于竞品平均，维持性价比定位。"

        return MARKDOWN_TEMPLATE.format(
            hotel_name=hotel_info["name"],
            generated_at=datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
            target_date=hotel_info["target_date"],
            district=hotel_info.get("district", ""),
            lat=hotel_info["lat"],
            lon=hotel_info["lon"],
            brand=hotel_info["brand"],
            star=hotel_info["star"],
            weekday_price=hotel_info["weekday_price"],
            max_distance_km=hotel_info.get("max_distance_km", 5),
            scenario=hotel_info.get("scenario", "default"),
            competitor_table=competitor_table,
            count_foreign=count_foreign,
            count_domestic=count_domestic,
            count_price_low=count_price_low,
            count_price_mid=count_price_mid,
            count_price_high=count_price_high,
            auto_expand_note=auto_expand_note,
            competitor_count=len(grouped.strong_relevant),
            price_conservative=cons.get("price", 0),
            rate_conservative=cons.get("rate", 0),
            price_standard=std.get("price", 0),
            rate_standard=std.get("rate", 0),
            price_aggressive=agg.get("price", 0),
            rate_aggressive=agg.get("rate", 0),
            strategy_emoji=self._strategy_emoji(rec.strategy),
            strategy_name=rec.strategy.value,
            price_recommended=rec.recommended_price,
            rate_recommended=rec.rate,
            confidence=rec.confidence,
            reasoning=reasoning_list,
            key_insight=insight
        )

    def _render_html(self, hotel_info: Dict, rec: PricingRecommendation, grouped: GroupedCompetitors) -> str:
        # 竞品表格HTML
        competitor_rows = []
        for s in competitors:
            dist = f"{s.hotel.distance_km:.1f}km" if s.hotel.distance_km else "N/A"
            competitor_rows.append(f"<tr><td>{s.hotel.name}</td><td>{dist}</td><td>{s.hotel.star}</td><td>{s.total_score:.1f}</td></tr>")
        competitor_table = "\n".join(competitor_rows)

        # 定价表格HTML
        alt = {a["strategy"]: a for a in rec.alternatives}
        pricing_rows = []
        strategy_names = {
            "conservative": ("🛡️ 保守",),
            "standard": ("⚖️ 标准",),
            "aggressive": ("🚀 激进",)
        }
        for s in ["conservative", "standard", "aggressive"]:
            if s in alt:
                a = alt[s]
                name = strategy_names.get(s, (s,))[0]
                pricing_rows.append(f"<tr><td>{name}</td><td>¥{a['price']}</td><td>+{a['rate']:.1f}%</td></tr>")
        pricing_html = "\n".join(pricing_rows)

        # reasoning HTML
        reasoning_items = "\n".join([f"<li>{r}</li>" for r in rec.reasoning])

        # 关键洞察
        if rec.cpi_score > 120:
            insight = f"目标酒店CPI={rec.cpi_score:.1f}，当前定位高于竞品平均，可以考虑{rec.strategy.value}策略追求更高收益。"
        elif rec.cpi_score > 90:
            insight = f"目标酒店CPI={rec.cpi_score:.1f}，定位与竞品平均相当，标准策略性价比最佳。"
        else:
            insight = f"目标酒店CPI={rec.cpi_score:.1f}，当前价格低于竞品平均，维持性价比定位。"

        return HTML_TEMPLATE.format(
            hotel_name=hotel_info["name"],
            generated_at=datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
            target_date=hotel_info["target_date"],
            district=hotel_info.get("district", ""),
            lat=hotel_info["lat"],
            lon=hotel_info["lon"],
            brand=hotel_info["brand"],
            star=hotel_info["star"],
            weekday_price=hotel_info["weekday_price"],
            max_distance_km=hotel_info.get("max_distance_km", 5),
            scenario=hotel_info.get("scenario", "default"),
            competitor_table_html=competitor_table,
            competitor_count=len(competitors),
            pricing_rows_html=pricing_html,
            strategy_emoji=self._strategy_emoji(rec.strategy),
            strategy_name=rec.strategy.value,
            price_recommended=rec.recommended_price,
            rate_recommended=rec.rate,
            confidence=rec.confidence,
            reasoning_html=reasoning_items,
            key_insight=insight
        )

    def _strategy_emoji(self, strategy):
        emoji_map = {
            "conservative": "🛡️",
            "standard": "⚖️",
            "aggressive": "🚀",
            "premium": "💎",
        }
        return emoji_map.get(strategy.value, "📊")


def main():
    parser = argparse.ArgumentParser(description="批量生成竞品价格分析报告")
    parser.add_argument("--input", "-i", required=True, help="输入JSON文件")
    parser.add_argument("--output", "-o", required=True, help="输出目录")
    parser.add_argument("--api-key", "-k", required=True, help="高德地图API Key")
    args = parser.parse_args()

    # 创建输出目录
    os.makedirs(args.output, exist_ok=True)

    # 读取输入
    with open(args.input, "r", encoding="utf-8") as f:
        data = json.load(f)

    generator = ReportGenerator(args.api_key)

    results = []
    for hotel in data["hotels"]:
        print(f"\n{'='*60}")
        result = generator.generate_report(hotel, args.output)
        results.append(result)
        print(f"{'='*60}")

    print(f"\n✅ 全部完成！共生成 {len(results)} 份报告")
    for r in results:
        print(f"   {r['hotel']}: {r['markdown']}")

    # 生成索引
    index_path = os.path.join(args.output, "README.md")
    with open(index_path, "w", encoding="utf-8") as f:
        f.write(f"# 竞品价格分析报告集合\n\n")
        f.write(f"**生成时间**: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n")
        f.write(f"**来源**: {data.get('description', '批量生成')}\n\n")
        f.write("## 报告列表\n\n")
        for r in results:
            name = r['hotel']
            md = os.path.relpath(r['markdown'], args.output)
            html = os.path.relpath(r['html'], args.output)
            rec = r['recommendation']
            price = rec.recommended_price
            f.write(f"- [{name}]({md}) - 推荐价格 ¥{price}  \n")
            f.write(f"  [HTML版本]({html}) (手机友好)\n")

    print(f"\n📑 索引已生成: {index_path}")


if __name__ == "__main__":
    main()
